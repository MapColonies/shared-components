{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "noImplicitAny": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "sourceMap": true,
    "declaration": false,
    "rootDir": "src",
    "downlevelIteration": true,
    "types": ["node", "vite/client", "@types/jest"],
    "baseUrl": "./",
    "paths": {
      "@turf/bbox": ["../../node_modules/@turf/bbox/dist/js/index.d.ts"],
      "@turf/bbox-polygon": ["../../node_modules/@turf/bbox-polygon/dist/js/index.d.ts"],
      "@turf/area": ["../../node_modules/@turf/area/dist/js/index.d.ts"],
      "@turf/intersect": ["../../node_modules/@turf/intersect/dist/js/index.d.ts"],
      "@turf/rewind": ["../../node_modules/@turf/rewind/index.d.ts"]
    }
  },
  "include": ["src/components"],
  "exclude": ["**/node_modules/**", "node_modules", "./dist/**/*", "storybook-static/*/**", "src/**/*.spec.*", "src/**/*.stories.tsx"]
}
